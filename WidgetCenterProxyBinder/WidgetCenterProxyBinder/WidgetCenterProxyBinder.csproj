<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>
    <SupportedOSPlatformVersion>16.0</SupportedOSPlatformVersion>
    <RootNamespace>NativeLibrary</RootNamespace>
    <AssemblyName>NativeLibrary</AssemblyName>
    <IsBindingProject>true</IsBindingProject>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Deterministic>false</Deterministic>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="Properties/AssemblyInfo.cs" />
  </ItemGroup>
  <ItemGroup>
    <ObjcBindingApiDefinition Include="ApiDefinitions.cs" />
  </ItemGroup>
  <ItemGroup>
    <NativeReference Include="../../VendorFrameworks/WidgetCenterProxy.xcframework">
      <Kind>Framework</Kind>
      <Frameworks>Foundation WidgetKit Intents</Frameworks>
    </NativeReference>
  </ItemGroup>
</Project>
